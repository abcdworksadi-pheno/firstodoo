<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- On supprime d'abord l'ancienne action window pour pouvoir créer la client action avec le même ID -->
    <delete model="ir.actions.act_window" id="action_license_dashboard"/>
    
    <!-- Action pour le Dashboard (Client Action OWL) -->
    <record id="action_license_dashboard" model="ir.actions.client">
        <field name="name">Tableau de Bord des Licences</field>
        <field name="tag">license_dashboard</field>
    </record>
</odoo>
